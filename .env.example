# Core AI + media storage
OPENAI_API_KEY=
SHOPREEL_GENERATED_MEDIA_BUCKET=

# Provider mode: fal (preferred production), direct (legacy no-async), railway_legacy (optional migration path)
SHOPREEL_MEDIA_PROVIDER_MODE=fal

# fal.ai production provider (preferred)
# You can set either FAL_KEY or FAL_API_KEY.
FAL_KEY=
FAL_API_KEY=
# Optional override for the fal model used by ShopReel video jobs.
SHOPREEL_FAL_VIDEO_MODEL=fal-ai/veo3

# Optional legacy Railway video generation service (only when SHOPREEL_MEDIA_PROVIDER_MODE=railway_legacy)
# Direct/fal mode does not require Railway variables.
SHOPREEL_RAILWAY_VIDEO_BASE_URL=
SHOPREEL_RAILWAY_VIDEO_API_KEY=
