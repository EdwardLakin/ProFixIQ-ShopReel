# Core AI + media storage
OPENAI_API_KEY=
SHOPREEL_GENERATED_MEDIA_BUCKET=
SHOPREEL_MEDIA_PROVIDER_MODE=direct

# Optional legacy Railway video generation service (only when SHOPREEL_MEDIA_PROVIDER_MODE=railway_legacy)
# Base URL for your deployed Railway service (no trailing slash).
# Example: https://your-railway-service.up.railway.app
SHOPREEL_RAILWAY_VIDEO_BASE_URL=

# Shared secret used by both ShopReel and the Railway video service.
# Generate with: npm run shopreel:video:key
SHOPREEL_RAILWAY_VIDEO_API_KEY=
